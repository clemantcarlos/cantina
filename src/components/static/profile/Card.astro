---
import RightArrow from "@/icons/RightArrow.astro";

interface Props{
  title:string;
  description:string;
  ref?:string;
}
const { title, description, ref } = Astro.props

---
<a href={ref} class="w-full text-primary flex items-center justify-center gap-x-4 rounded-lg px-4 py-2 
  hover:cursor-pointer hover:bg-gray-200">
  <slot name="icon"/>
  <div class="flex-1 pt-4">
    <h2 class="text-xl font-bold">{title}</h2>
    <small class="text-xs">{description}</small>
    <!-- TODO - ADD THE LINK TO THE CARD COMPONENT -->
  </div>
  <RightArrow class="size-4 text-secondary"/>
</a>